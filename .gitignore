# Bỏ qua các thư mục chứa mã máy do Visual Studio tự sinh ra
bin/
obj/

# Bỏ qua các thư mục và cấu hình cá nhân của Visual Studio
.vs/
*.user
*.suo
*.sln.docstates

# Bỏ qua các file nhị phân, file thực thi và file debug
*.exe
*.dll
*.pdb
*.ilk

# Bỏ qua các file tạm, file log
*.log
*.tmp
*.bak
*.swp
*.cache/

# Bỏ qua cơ sở dữ liệu SQLite cục bộ (Nếu bạn không muốn push file db lên Git)
# Bỏ dấu # ở dòng dưới nếu muốn mỗi người tự tạo DB riêng khi chạy Server
